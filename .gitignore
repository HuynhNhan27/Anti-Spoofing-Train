# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a windows machine, Python path may vary
#   and causing issues.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains specific versions of dependencies
#   poetry.lock

# pdm
#   pdm stores project-wide configurations in .pdm.toml
.pdm.toml
#   pdm stores project-wide status in .pdm-python
.pdm-python
#   pdm stores local configurations in .pdm-env.toml
.pdm-env.toml

# PEP 582; used by e.g. github.com/lincolnloop/layman and github.com/pdm-project/pdm
__pypackages__/

